  "panels": [
    {
      "title": "Nginx — Requests/sec",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(nginx_http_requests_total[1m])",
          "legendFormat": "{{method}} {{status}}"
        }
      ]
    },
    {
      "title": "Nginx — Active Connections",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "nginx_connections_active",
          "legendFormat": "Active"
        }
      ]
    },
    {
      "title": "Nginx — Connections (Accepted/Handled)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "rate(nginx_connections_accepted[1m])",
          "legendFormat": "Accepted/s"
        },
        {
          "expr": "rate(nginx_connections_handled[1m])",
          "legendFormat": "Handled/s"
        }
      ]
    },
    {
      "title": "App Go — Health (Up/Down)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "up{job=\"app-go\"}",
          "legendFormat": "app-go"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      }
    },
    {
      "title": "App Python — Health (Up/Down)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "up{job=\"app-python\"}",
          "legendFormat": "app-python"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      }
    }
